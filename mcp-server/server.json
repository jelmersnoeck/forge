{
  "name": "forge",
  "version": "0.1.0",
  "description": "MCP server exposing Forge agent capabilities - execute code, search files, manage background tasks, and more",
  "author": "Jelmer Snoeck",
  "homepage": "https://github.com/jelmersnoeck/forge",
  "repository": {
    "type": "git",
    "url": "https://github.com/jelmersnoeck/forge.git"
  },
  "capabilities": ["tools", "resources"],
  "transports": ["stdio", "streamableHttp"],
  "config": {
    "stdio": {
      "command": "npx",
      "args": ["-y", "forge-mcp-server"],
      "env": {
        "WORKSPACE_DIR": "/path/to/your/workspace"
      }
    },
    "http": {
      "url": "https://your-server.example.com/mcp"
    }
  },
  "tools": [
    "Read",
    "Write",
    "Edit",
    "Bash",
    "Grep",
    "Glob",
    "WebSearch",
    "Reflect",
    "TaskCreate",
    "TaskGet",
    "TaskList",
    "TaskStop",
    "TaskOutput",
    "Agent",
    "AgentGet",
    "AgentList",
    "AgentStop"
  ],
  "resources": [
    "forge://readme",
    "forge://claude"
  ]
}
